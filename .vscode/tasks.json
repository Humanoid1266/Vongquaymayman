{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build SFML + Winsock project",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "${file}",
                "-ID:/dowload/SFML-2.5.1-windows-gcc-7.3.0-mingw-64-bit/SFML-2.5.1/include",
                "-LD:/dowload/SFML-2.5.1-windows-gcc-7.3.0-mingw-64-bit/SFML-2.5.1/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-lws2_32",
                "-o",
                "${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
