#include <iostream>
#include <winsock2.h>
#include <ws2tcpip.h>
#include <SFML/Graphics.hpp>
#include <cstring>

#pragma comment(lib, "ws2_32.lib")

#define SERVER_ADDR "127.0.0.1"
#define PORT 2808

int main() {
    // Khởi tạo Winsock
    WSADATA wsaData;
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        std::cerr << "Khong khoi tao duoc Winsock\n";
        return 1;
    }

    SOCKET clientSocket = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    if (clientSocket == INVALID_SOCKET) {
        std::cerr << "Khong tao duoc socket\n";
        WSACleanup();
        return 1;
    }

    sockaddr_in serverAddr = {};
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(PORT);
    serverAddr.sin_addr.s_addr = inet_addr(SERVER_ADDR);

    if (connect(clientSocket, (sockaddr*)&serverAddr, sizeof(serverAddr)) == SOCKET_ERROR) {
        std::cerr << "Ket noi toi server that bai\n";
        closesocket(clientSocket);
        WSACleanup();
        return 1;
    }

    // SFML window
    sf::RenderWindow window(sf::VideoMode(800, 600), "Vong Quay May Man");

    sf::Font font;
    if (!font.loadFromFile("OpenSans_Condensed-Bold.ttf")) {
        std::cerr << "Khong tim thay file font OpenSans_Condensed-Bold.ttf\n";
        closesocket(clientSocket);
        WSACleanup();
        return 1;
    }

    sf::Text resultText("", font, 24);
    resultText.setPosition(300, 50);
    resultText.setFillColor(sf::Color::Blue);

    sf::CircleShape wheel(200, 60);
    wheel.setOrigin(200, 200);
    wheel.setPosition(400, 300);

    sf::RectangleShape pointer(sf::Vector2f(20, 60));
    pointer.setFillColor(sf::Color::Red);
    pointer.setPosition(390, 80);

    sf::RectangleShape spinButton(sf::Vector2f(120, 50));
    spinButton.setFillColor(sf::Color::Green);
    spinButton.setPosition(340, 520);

    sf::Text spinText("SPIN", font, 20);
    spinText.setFillColor(sf::Color::White);
    spinText.setPosition(370, 530);

    bool isSpinning = false;
    float angle = 0;
    sf::Clock spinClock;

    while (window.isOpen()) {
        sf::Event event;
        while (window.pollEvent(event)) {
            if (event.type == sf::Event::Closed) window.close();

            if (event.type == sf::Event::MouseButtonPressed &&
                event.mouseButton.button == sf::Mouse::Left) {
                if (spinButton.getGlobalBounds().contains(event.mouseButton.x, event.mouseButton.y)) {
                    isSpinning = true;
                    spinClock.restart();
                }
            }
        }

        if (isSpinning) {
            float elapsed = spinClock.getElapsedTime().asSeconds();
            if (elapsed < 3.0f) {
                angle += 15;
                wheel.setRotation(angle);
            } else {
                isSpinning = false;

                const char* msg = "SPIN";
                send(clientSocket, msg, (int)strlen(msg), 0);

                char buffer[1024];
                int received = recv(clientSocket, buffer, 1023, 0);
                if (received > 0) {
                    buffer[received] = '\0';
                    resultText.setString(buffer);
                }
            }
        }

        window.clear(sf::Color::White);
        window.draw(wheel);
        window.draw(pointer);
        window.draw(spinButton);
        window.draw(spinText);
        window.draw(resultText);
        window.display();
    }

    closesocket(clientSocket);
    WSACleanup();
    return 0;
}
